# Only use PHP values if mod_php is available
<IfModule mod_php.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 55M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value memory_limit 256M
</IfModule>

Options -Indexes

RewriteEngine On
RewriteBase /

# Existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# User profile
RewriteRule ^user/@([^/]+)/?$ user/profile.php?username=$1 [L,QSA]

# Post view
RewriteRule ^post/([a-f0-9]+)/?$ post-view.php?hash=$1 [L,QSA]

# Blog
RewriteRule ^blog/?$ blog/index.php [L]
RewriteRule ^blog/([^/]+)/?$ blog/single.php?slug=$1 [L,QSA]

# Games
RewriteRule ^games/play/([^/]+)/?$ games/play.php?slug=$1 [L,QSA]

# Default
RewriteRule ^$ index.php [L]

# Prevent access to sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

ServerSignature Off

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php81” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
